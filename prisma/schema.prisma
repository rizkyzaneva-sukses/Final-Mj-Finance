generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionSource {
  QRIS_XLSX
  BANK_PDF
  BANK_SCREENSHOT
  MANUAL
}

enum TransactionDirection {
  IN
  OUT
}

enum TransactionStatus {
  MATCHED
  UNMATCHED
  SKIPPED
}

enum ImportStatus {
  PROCESSING
  REVIEW
  COMPLETED
  FAILED
}

model Ministry {
  id           String        @id @default(cuid())
  code         Int           @unique
  name         String
  active       Boolean       @default(true)
  events       Event[]
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Event {
  id           String        @id @default(cuid())
  name         String
  category     String?
  active       Boolean       @default(true)
  ministryId   String
  ministry     Ministry      @relation(fields: [ministryId], references: [id], onDelete: Restrict)
  incomeTypes  IncomeType[]
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([ministryId, name])
  @@index([ministryId])
}

model IncomeType {
  id           String        @id @default(cuid())
  name         String
  uniqueCode   String?       @unique
  active       Boolean       @default(true)
  eventId      String
  incomeMasterId String?
  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  incomeMaster IncomeMaster? @relation(fields: [incomeMasterId], references: [id], onDelete: SetNull)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([eventId, name])
  @@index([eventId])
  @@index([incomeMasterId])
}

model IncomeMaster {
  id         String       @id @default(cuid())
  name       String       @unique
  active     Boolean      @default(true)
  mappings   IncomeType[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model ExpenseType {
  id           String        @id @default(cuid())
  name         String        @unique
  active       Boolean       @default(true)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ImportBatch {
  id            String            @id @default(cuid())
  fileName      String
  source        TransactionSource
  accountHolder String?
  accountNumber String?
  status        ImportStatus      @default(PROCESSING)
  totalRows     Int               @default(0)
  importedRows  Int               @default(0)
  duplicateRows Int               @default(0)
  matchedRows   Int               @default(0)
  unmatchedRows Int               @default(0)
  skippedRows   Int               @default(0)
  errorMessage  String?
  transactions  Transaction[]
  createdAt     DateTime          @default(now())
  completedAt   DateTime?
}

model Transaction {
  id              String               @id @default(cuid())
  transactionDate DateTime
  description     String
  amount          Decimal              @db.Decimal(18, 2)
  direction       TransactionDirection
  source          TransactionSource
  accountHolder   String?
  accountNumber   String?
  sourceReference String?
  fingerprint     String               @unique
  isDraft         Boolean              @default(false)
  status          TransactionStatus    @default(UNMATCHED)
  skipReason      String?
  rawData         Json?
  importBatchId   String?
  importBatch     ImportBatch?         @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  ministryId      String?
  ministry        Ministry?            @relation(fields: [ministryId], references: [id], onDelete: Restrict)
  eventId         String?
  event           Event?               @relation(fields: [eventId], references: [id], onDelete: Restrict)
  incomeTypeId    String?
  incomeType      IncomeType?          @relation(fields: [incomeTypeId], references: [id], onDelete: Restrict)
  expenseTypeId   String?
  expenseType     ExpenseType?         @relation(fields: [expenseTypeId], references: [id], onDelete: Restrict)
  assignedAt      DateTime?
  assignedByRole  String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([transactionDate])
  @@index([status])
  @@index([isDraft])
  @@index([ministryId])
  @@index([eventId])
  @@index([expenseTypeId])
  @@index([importBatchId])
}

model QrisReset {
  id            String   @id @default(cuid())
  accountNumber String?
  accountHolder String?
  resetAt       DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([accountNumber])
}
